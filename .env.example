# Copy to .env.local for local dev (vercel dev) and set the same vars in Vercel.

# Supabase Postgres — use the "Connection pooling" string (Transaction mode,
# port 6543) from Supabase → Project Settings → Database → Connection string.
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres"

# Secret used to sign admin login tokens. Use a long random string, e.g.
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-string"

# Single admin login
ADMIN_USERNAME="admin"
# Generate the hash with:  node scripts/hash-password.mjs 'your-password'
ADMIN_PASSWORD_HASH="$2a$10$replace-with-the-generated-hash"

# Vercel Blob (image uploads) — from the Vercel project's Storage tab
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
